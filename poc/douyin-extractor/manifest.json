{
  "manifest_version": 3,
  "name": "ClipMiner PoC — Douyin Extractor",
  "version": "0.1.0",
  "description": "Douyin 영상 → mp4 → ClipMiner Web 작업 폴더 저장 + 라이브러리 자동 등록. 로컬 unpacked, Chrome.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["https://*/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://www.douyin.com/*",
        "https://www.iesdouyin.com/share/video/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://clipminer.cozybuilder.co.kr/*"
      ],
      "js": ["web-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
